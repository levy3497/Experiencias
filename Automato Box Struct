#include <iostream>
#include <string>
#include <ctime>
#include <cstdlib>

using namespace std;

struct automato_box {
    string nome;
    float energia;
    int ataque;
    int defesa;
    int vitorias;
    int derrotas;
};

int introducao() {
    int escolha;
    cout << "Automato Fight Version 0.2\n";
    cout << "Comecar 1) Sair)0\n";
    cin >> escolha;
    return escolha;
}

void textos_imersivos() {
    string texto[] = {
        "O som do seu automato batendo no saco de boxe o deixa ainda mais tenso a proxima luta sera pra valer...\n",
        "Voce assiste as fitas do seu proximo adversario calmamente bolando alguma estrategia pra derruba-lo...\n",
        "Ao longe pode se ver voce no escuro consertado as maos do seu automato para sua proxima batalha...\n"
    };

    int texto_para_aparecer = rand() % 3;
