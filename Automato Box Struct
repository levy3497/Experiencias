void montar_automato(automato_box &automato_funcao_montar) {
    cin.ignore();
    cout << "Diga o nome do seu Automato: ";
    getline(cin, automato_funcao_montar.nome);
    cout << "Digite total de energia: (seu inimigo tera a mesma quantidade): ";
    cin >> automato_funcao_montar.energia;
}

void distribuir_pontos_automato(automato_box &automato_pontos_energia) {
    cout << "Voce tem um Total de: " << automato_pontos_energia.energia << " pontos de energia\n";
    cout << "distribua esses pontos entre Ataque e Defesa para conseguir ter seu Automato!\n";

    while (true) {
        cout << "Ataque: ";
        cin >> automato_pontos_energia.ataque;

        cout << "Voce ainda tem um total de pontos de: "
             << automato_pontos_energia.energia - automato_pontos_energia.ataque << '\n';

        cout << "Defesa: ";
        cin >> automato_pontos_energia.defesa;

        if (automato_pontos_energia.ataque + automato_pontos_energia.defesa
            == automato_pontos_energia.energia) {
            break;
        }

        if (automato_pontos_energia.ataque + automato_pontos_energia.defesa
            > automato_pontos_energia.energia) {
            cout << "a soma de ataque e defesa passa de sua energia total\n";
        } else {
            cout << "pontos sobrando use todos os restantes\n";
        }
    }
}

void nome_automato_ia(automato_box &automato_funcao_montar_ia) {
    string nomes_automatos_ia[] = {
        "Iron Havoc",
        "Apex Predator",
        "Circuit Breaker",
        "Titan Crush",
        "Vengeance",
        "Steel Viper",
        "Nitro Hammer",
        "Omega Core",
        "Rust Reaper",
        "Volt Stryker"
    };

    int nome_aleatorio = rand() % 10;
    automato_funcao_montar_ia.nome = nomes_automatos_ia[nome_aleatorio];
}

void distribuir_pontos_automato_ia(automato_box &automato_pontos_ia,automato_box &automato_main) {
    automato_pontos_ia.energia = automato_main.energia;
    automato_pontos_ia.ataque = rand() % (int)automato_pontos_ia.energia;
    automato_pontos_ia.defesa =
        automato_pontos_ia.energia - automato_pontos_ia.ataque;
}

void historico_lutas_automato(automato_box &automato_funcao_historico) {
    automato_funcao_historico.vitorias = rand() % 100;
    automato_funcao_historico.derrotas = rand() % 100;
}

void imprimir_automato(automato_box &automato_funcao_imprimir) {
    cout << "-------SEU CAMPEAO-------\n";
    cout << "Nome: " << automato_funcao_imprimir.nome << '\n';
    cout << "Energia: " << automato_funcao_imprimir.energia << '\n';
    cout << "Ataque: " << automato_funcao_imprimir.ataque << '\n';
    cout << "Defesa: " << automato_funcao_imprimir.defesa << '\n';
    cout << "Vitorias: " << automato_funcao_imprimir.vitorias << '\n';
    cout << "Derrotas: " << automato_funcao_imprimir.derrotas << '\n';
    cout << "-------------------------\n";
}

int combate_automatos(automato_box &automato_main, automato_box &automato_main_ia){
    int ganhador;
    int vida_player = automato_main.energia;
    int vida_ia = automato_main_ia.energia;
    int quem_comeca =rand() % 2;
    cout << "A luta comecou!!\n";
    while (vida_player > 0 && vida_ia > 0){
        if (quem_comeca == 0){
            int escolha_acao_player;
            cout << "Player Agora!\n";
            cout << "1)Atacar 2)Contra-Atacar";
            cin >> escolha_acao_player;
            if (escolha_acao_player == 1){
                cout << automato_main.nome << " Atacou total de: " << automato_main.ataque << " Causando um total de: ";
                if (automato_main.ataque - automato_main_ia.defesa > 0){
                    cout << automato_main.ataque - automato_main_ia.defesa << '\n';
                    cout << "Sua vida total e de: " << vida_ia << '\n';
                    vida_ia -= automato_main.ataque - automato_main_ia.defesa;
                }
                else if (automato_main.ataque - automato_main_ia.defesa <= 0){
                    cout << "Voce so deu 1 de dano!\n";
                    cout << "Sua vida total e de: " << vida_ia << '\n';
                    vida_ia -=1;
                }
            }
            else if(escolha_acao_player == 2){
                int chance_acerto = rand() % 2;
                if (chance_acerto == 0 ){
                    cout << "Seu contra ataque foi bem sucedido e voce ira dar dano cheio!\n";
                    cout << "Sua vida total e de: " << vida_ia << '\n';
                    vida_ia -= automato_main.ataque;
                }
                else if (chance_acerto == 1){
                    const float numero_porcentagem_ataque = 0.5;
                    cout << "Seu contra ataque foi mal sucedido e voce ira receber metade do dano normal dele!\n";
                    cout << "Sua vida total e de: " << vida_ia << '\n';
                    vida_player -= numero_porcentagem_ataque * automato_main_ia.ataque;
                }
            }
            quem_comeca = 1;
        }
        else{
            cout << "I.A Agora\n";
            int escolha_ia = rand() % 2;
            if (escolha_ia == 0){
                  cout << automato_main_ia.nome << " Atacou total de: " << automato_main_ia.ataque << " Causando um total de: ";
                if (automato_main_ia.ataque - automato_main.defesa > 0){
                    cout << automato_main_ia.ataque - automato_main.defesa << '\n';
                    cout << "Sua vida total e de: " << vida_player << '\n';
                    vida_player -= automato_main_ia.ataque - automato_main.defesa;
                }
                else if (automato_main_ia.ataque - automato_main.defesa <= 0){
                    cout << "Voce Recebeu 1 de dano!\n";
                    cout << "Sua vida total e de: " << vida_player << '\n';
                    vida_player -=1;
                }
            }
            else if(escolha_ia == 1){
                int chance_acerto = rand() % 2;
                if(chance_acerto == 0){
                    cout << "O contra ataque de "<< automato_main_ia.nome <<" foi bem sucedido e voce ira dar dano cheio!\n";
                    vida_player -= automato_main_ia.ataque;
                    cout << "Sua vida total e de: " << vida_player << '\n';
                }
                else if(chance_acerto == 1){
                    const float numero_porcentagem_ataque = 0.5;
                    cout << "O contra ataque de "<< automato_main_ia.nome << " foi mal sucedido!\n";
                    vida_ia -= numero_porcentagem_ataque * automato_main.ataque;
                    cout << "Sua vida total e de: " << vida_player << '\n';
                }
            }
                
            quem_comeca = 0;
        }
    }
    if (vida_player > vida_ia){
        ganhador = 1;
    }
    else{
        ganhador = 0;
    }
    return ganhador;
}

int main() {
    unsigned seed = time(nullptr);
    srand(seed);

    automato_box automato_main;
    automato_box automato_main_ia;

    int escolha = introducao();

    if (escolha == 1) {
        montar_automato(automato_main);
        historico_lutas_automato(automato_main);
        textos_imersivos();
        distribuir_pontos_automato(automato_main);
        imprimir_automato(automato_main);

        nome_automato_ia(automato_main_ia);
        distribuir_pontos_automato_ia(automato_main_ia, automato_main);
        historico_lutas_automato(automato_main_ia);
        imprimir_automato(automato_main_ia);

        int ganhador = combate_automatos(automato_main, automato_main_ia);
        if (ganhador == 1){
            cout << "voce ganhou\n";
        }
        else{
            cout << "ia ganhou\n";
        }
    } else {
        cout << "Saindo...";
    }

    return 0;
}
